# name: test/sql/optimizer/topn_window_elimination_arg_order.test
# description: top_n_window_elimination must respect a ROW_NUMBER argument-level ORDER BY (issue #23678)
# group: [optimizer]

# A ROW_NUMBER with an argument-level ORDER BY computes the row number using that ordering
# instead of the window frame ordering. The rewrite must not eliminate this window with the
# frame ordering (which would pick the wrong rows).

query III
SELECT id, g, p
FROM (VALUES
  (1, 1, 1),
  (2, 1, 2),
  (3, 1, 3),
  (4, 2, 1),
  (5, 2, 2)
) AS t(id, g, p)
QUALIFY ROW_NUMBER(ORDER BY id DESC) OVER (
  PARTITION BY g
  ORDER BY p ASC
  ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
) <= 1
ORDER BY g, id;
----
3	1	3
5	2	2

# The optimized result must match the result with the rewrite disabled.
statement ok
SET disabled_optimizers = 'top_n_window_elimination'

query III
SELECT id, g, p
FROM (VALUES
  (1, 1, 1),
  (2, 1, 2),
  (3, 1, 3),
  (4, 2, 1),
  (5, 2, 2)
) AS t(id, g, p)
QUALIFY ROW_NUMBER(ORDER BY id DESC) OVER (
  PARTITION BY g
  ORDER BY p ASC
  ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING
) <= 1
ORDER BY g, id;
----
3	1	3
5	2	2
