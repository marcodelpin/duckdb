# name: test/sql/optimizer/topn_window_elimination_nullable_order.test
# description: top_n_window_elimination must keep NULL-keyed rows when ROW_NUMBER orders by a nullable expression (issue #23677)
# group: [optimizer]

statement ok
CREATE TABLE t(id INTEGER PRIMARY KEY);

statement ok
INSERT INTO t VALUES (1), (2), (3);

# A compound ORDER BY expression (NULLIF) can produce NULLs even though id is NOT NULL.
# The rewrite must use the nulls-last aggregate variant so the NULL-keyed row is kept, not dropped.
query II
SELECT id, ROW_NUMBER() OVER (ORDER BY NULLIF(id % 3, 0) DESC NULLS LAST) AS rn
FROM t
QUALIFY rn <= 3
ORDER BY rn;
----
2	1
1	2
3	3

# Same bug with a PARTITION BY (the rewrite is active per partition).
statement ok
CREATE TABLE t2(g INTEGER, id INTEGER);

statement ok
INSERT INTO t2 VALUES (1,1),(1,2),(1,3),(2,4),(2,5),(2,6);

query III
SELECT g, id, ROW_NUMBER() OVER (PARTITION BY g ORDER BY NULLIF(id % 3, 0) DESC NULLS LAST) AS rn
FROM t2
QUALIFY rn <= 3
ORDER BY g, rn;
----
1	2	1
1	1	2
1	3	3
2	5	1
2	4	2
2	6	3

# The optimized results must match the results with the rewrite disabled.
statement ok
SET disabled_optimizers = 'top_n_window_elimination'

query III
SELECT g, id, ROW_NUMBER() OVER (PARTITION BY g ORDER BY NULLIF(id % 3, 0) DESC NULLS LAST) AS rn
FROM t2
QUALIFY rn <= 3
ORDER BY g, rn;
----
1	2	1
1	1	2
1	3	3
2	5	1
2	4	2
2	6	3
